# ══════════════════════════════════════════════════════════════════════════════
# SHAJA-AL-ZAHABI — Environment Variables Example
# Copy this to .env and fill in real values. NEVER commit .env to Git.
# ══════════════════════════════════════════════════════════════════════════════

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=shaja_db
DB_USER=shaja_admin
DB_PASSWORD=changeme_use_a_strong_password

# Service ports
INVENTORY_PORT=3001
POS_PORT=3002
CRM_PORT=3003

# Inter-service URLs (used in Docker Compose / Kubernetes networking)
INVENTORY_SERVICE_URL=http://inventory-service:3001
POS_SERVICE_URL=http://pos-service:3002
CRM_SERVICE_URL=http://crm-service:3003
